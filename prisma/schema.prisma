// Prisma Schema — Plataforma de Venda de Fotos
// Deploy: Supabase PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  ADMIN
  BUYER
  PHOTOGRAPHER
}

enum AlbumStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PhotoStatus {
  ACTIVE
  HIDDEN
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

// ─── Models ──────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  supabaseUserId String   @unique
  name           String
  email          String   @unique
  avatarUrl      String?
  phone          String?
  role           UserRole @default(BUYER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  albums Album[]

  @@map("users")
}

model Album {
  id                String      @id @default(cuid())
  photographerId    String
  title             String
  slug              String      @unique
  description       String?
  eventDate         DateTime?
  location          String?
  coverImageUrl     String?
  defaultPhotoPrice Int         @default(0) // Price in centavos (BRL)
  isFeatured        Boolean     @default(false)
  promotionEnabled  Boolean     @default(false)
  promotionMinPhotos Int        @default(0)
  promotionDiscountBps Int      @default(0) // 10000 = 100%
  status            AlbumStatus @default(DRAFT)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  photographer User    @relation(fields: [photographerId], references: [id], onDelete: Cascade)
  photos       Photo[]
  folders      AlbumFolder[]
  orders       Order[]

  @@index([photographerId])
  @@index([slug])
  @@index([isFeatured])
  @@map("albums")
}

model Photo {
  id               String      @id @default(cuid())
  albumId          String
  folderId         String?
  originalFileName String
  originalMimeType String
  driveFileId      String
  previewR2Key     String
  previewUrl       String
  price            Int         @default(0) // Price in centavos (BRL)
  width            Int?
  height           Int?
  fileSize         Int?        // In bytes
  status           PhotoStatus @default(ACTIVE)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  album      Album        @relation(fields: [albumId], references: [id], onDelete: Cascade)
  folder     AlbumFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  orderItems OrderItem[]

  @@index([albumId])
  @@index([folderId])
  @@map("photos")
}

model AlbumFolder {
  id        String   @id @default(cuid())
  albumId   String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  album  Album   @relation(fields: [albumId], references: [id], onDelete: Cascade)
  photos Photo[]

  @@unique([albumId, name])
  @@index([albumId])
  @@map("album_folders")
}

model Order {
  id                       String      @id @default(cuid())
  orderNumber              String      @unique @default(cuid())
  albumId                  String
  customerName             String
  customerEmail            String
  customerPhone            String
  customerDocument         String?
  status                   OrderStatus @default(PENDING)
  totalAmount              Int         @default(0) // In centavos
  mercadoPagoPreferenceId  String?
  mercadoPagoPaymentId     String?
  accessToken              String      @unique
  accessTokenExpiresAt     DateTime
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  album       Album        @relation(fields: [albumId], references: [id])
  items       OrderItem[]
  paymentLogs PaymentLog[]

  @@index([accessToken])
  @@index([albumId])
  @@index([mercadoPagoPaymentId])
  @@map("orders")
}

model OrderItem {
  id               String    @id @default(cuid())
  orderId          String
  photoId          String
  price            Int       // Snapshot do preço no momento da compra (centavos)
  downloadCount    Int       @default(0)
  lastDownloadedAt DateTime?
  createdAt        DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  photo Photo @relation(fields: [photoId], references: [id])

  @@unique([orderId, photoId])
  @@map("order_items")
}

model PaymentLog {
  id         String   @id @default(cuid())
  orderId    String?
  provider   String   @default("mercadopago")
  eventType  String
  externalId String?
  payload    Json
  createdAt  DateTime @default(now())

  order Order? @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([externalId])
  @@map("payment_logs")
}
